# Example .env file for Birthday Bot
BOT_TOKEN=YOUR_TELEGRAM_BOT_TOKEN_HERE
WEBSITE_URL=http://localhost:3000

# -------------------------
# 🛡️ HOW TO FIX TELEGRAM API BLOCKS
# -------------------------
# Option A: Use a custom API Endpoint (no VPN/Proxy needed)
# If Telegram is blocked, you can use a mirror like teleapi.dev.
# Uncomment the line below (remove the #) to use it:
# BASE_URL=https://teleapi.dev/api/bot

# Option B: Use a Local Proxy
# If you run a proxy App (like v2ray/clash) on your PC, set its HTTP proxy here:
# PROXY_URL=http://127.0.0.1:10809
